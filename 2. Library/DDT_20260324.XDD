				<comment>0 = ATV9xx drive instance for going Forward OR Reverse, use VFD_ATV9xxx IN/OUT on Object</comment>
			</variables>
			<variables name="O_VFD_ATV9XX_F" typeName="INT">
				<comment>1 = ATV9xx drive instance for going Forward, use VFD_ATV9xxx IN/OUT on Object</comment>
			</variables>
			<variables name="O_VFD_ATV3XX_FR" typeName="INT">
				<comment>2 = ATV3xx drive instance for going Forward OR Reverse, use VFD_ATV3xxx IN/OUT on Object</comment>
			</variables>
			<variables name="O_VFD_ATV3XX_F" typeName="INT">
				<comment>3 = ATV3xx drive instance for going Forward, use VFD_ATV3xxx IN/OUT on Object</comment>
			</variables>
			<variables name="O_DOL_TESYS_S_FR" typeName="INT">
				<comment>10 = Tesys island DOL that can be set Forward OR Reverse, useTeSys Safety IN/OUT on Object, Avatar should be safety (Red avatar) </comment>
			</variables>
			<variables name="O_DOL_TESYS_S_F" typeName="INT">
				<comment>11 = Tesys island DOL that can be set Forward, useTeSys Safety IN/OUT on Object, Avatar should be safety (Red avatar) </comment>
			</variables>
			<variables name="O_DOL_FR" typeName="INT">
				<comment>12 = Normal DOL instance that goes Forward OR Reverse, this DOL uses normal IO, connect Inputs/Outputs accordignly on Object</comment>
			</variables>
			<variables name="O_DOL_F" typeName="INT">
				<comment>13 = Normal DOL instance that goes Forward, this DOL uses normal IO, connect Inputs/Outputs accordignly on Object</comment>
			</variables>
			<variables name="O_DOL_TESYS_N_FR" typeName="INT">
				<comment>14 = Tesys island DOL that can be set Forward OR Reverse, useTeSys Normal  IN/OUT on Object, Avatar should be Normal (Green avatar) </comment>
			</variables>
			<variables name="O_DOL_TESYS_N_F" typeName="INT">
				<comment>15 = Tesys island DOL that can be set Forward, useTeSys Normal IN/OUT on Object, Avatar should be Normal (Green avatar) </comment>
			</variables>
			<variables name="O_SH" typeName="INT">
				<comment>20 = Shredder?</comment>
			</variables>
			<variables name="O_OPT" typeName="INT">
				<comment>21 = Optical Sorter, attach Ethernet/IP data to according Input or Output of the Object</comment>
			</variables>
			<variables name="S_VFD" typeName="INT">
				<comment>Storage object with a conveyor that is controlled by a VFD (VFD = Variable Frequency Drive )</comment>
			</variables>
			<variables name="S_DOL" typeName="INT">
				<comment>Storage object with a conveyor that is controlled by a starter (DOL = Direct OnLine )</comment>
			</variables>
			<variables name="S_FIXED" typeName="INT">
				<comment>Storage object as fixed bin (no movement, except the door)</comment>
			</variables>
			<variables name="S_UNKOWN" typeName="INT">
				<comment>Storage object with preserved setting, no idea what 10 should be</comment>
			</variables>
		</structure>
	</DDTSource>
