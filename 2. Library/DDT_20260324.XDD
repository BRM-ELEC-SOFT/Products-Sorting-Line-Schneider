				<attribute name="InstancesProgramAccessRight" value="1"></attribute>
			</variables>
			<variables name="ETH_PORT3_BKP_STATUS" typeName="BYTE">
				<comment>Ethernet port 3 and backplane port status</comment>
				<attribute name="RequestAccessRight" value="1"></attribute>
				<attribute name="InstancesProgramAccessRight" value="1"></attribute>
			</variables>
			<variables name="FIRMWARE_VERSION" typeName="WORD">
				<comment>MSB=Major Revision, LSB=Minor Revision</comment>
				<attribute name="RequestAccessRight" value="1"></attribute>
				<attribute name="InstancesProgramAccessRight" value="1"></attribute>
			</variables>
			<variables name="FDR_USAGE" typeName="BYTE">
