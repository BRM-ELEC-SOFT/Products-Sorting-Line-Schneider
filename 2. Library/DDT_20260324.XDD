	<DDTSource DDTName="MBEthEngParam" version="1.00" dateTime="dt#2019-11-18-10:44:07">
		<comment>MBTCP Client Engineering Parameters</comment>
		<attribute name="TypeSignatureCheckSumString" value="DEC7"></attribute>
		<structure>
			<variables name="CommFailRetries" typeName="INT">
				<comment>Number of retries in case of a communication failure</comment>
			</variables>
			<variables name="Timeout" typeName="TIME">
				<comment>Time for which client will wait for a response, once the request is initiated, before moving to fail state</comment>
			</variables>
			<variables name="InactivityTime" typeName="TIME">
				<comment>The period for which the client will not initiate a request after the retries are expired.</comment>
			</variables>
			<variables name="ResetDataOnFail" typeName="BOOL">
				<comment>Reset the data on fail of request instead of holding</comment>
			</variables>
		</structure>
	</DDTSource>
