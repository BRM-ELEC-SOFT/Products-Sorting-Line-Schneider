			</variables>
			<variables name="Warning" typeName="BOOL">
				<comment>TRUE = 1 or more Warning alarms are present</comment>
			</variables>
			<variables name="Info" typeName="BOOL">
				<comment>TRUE = 1 or more Info alarms are present</comment>
			</variables>
			<variables name="NumberOfAlarms_Safety" typeName="INT">
				<comment>Present number of active Safety alarms</comment>
			</variables>
			<variables name="NumberOfAlarms_Error" typeName="INT">
				<comment>Present number of active Error alarms</comment>
			</variables>
			<variables name="NumberOfAlarms_Warning" typeName="INT">
				<comment>Present number of active Warning alarms</comment>
			</variables>
			<variables name="NumberOfAlarms_Info" typeName="INT">
				<comment>Present number of active Info alarms</comment>
			</variables>
		</structure>
