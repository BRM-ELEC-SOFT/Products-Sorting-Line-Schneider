				<attribute name="RequestAccessRight" value="1"></attribute>
				<attribute name="InstancesProgramAccessRight" value="1"></attribute>
			</variables>
			<variables name="LLDP_SERVICE" typeName="BOOL">
				<comment>LLDP service status</comment>
				<attribute name="ExtractBit" value="1"></attribute>
				<attribute name="RequestAccessRight" value="1"></attribute>
				<attribute name="InstancesProgramAccessRight" value="1"></attribute>
			</variables>
			<variables name="EVENT_LOG_STATUS" typeName="BOOL">
				<comment>0: event log service not operating normally / 1: event log service operating normally or disabled</comment>
				<attribute name="ExtractBit" value="2"></attribute>
				<attribute name="RequestAccessRight" value="1"></attribute>
				<attribute name="InstancesProgramAccessRight" value="1"></attribute>
			</variables>
			<variables name="LOG_SERVER_NOT_REACHABLE" typeName="BOOL">
