	<DDTSource DDTName="udtMCCInputs" version="0.05" dateTime="dt#2025-12-16-22:50:49">
		<attribute name="TypeSignatureCheckSumString" value="9FA4"></attribute>
		<structure>
			<variables name="MainSwitchClosed" typeName="BOOL">
				<comment>TRUE = Closed, if FALSE, is this signal connected or is it used?</comment>
			</variables>
			<variables name="ClimateControl1Alarm" typeName="BOOL">
				<comment>TRUE = Alarm</comment>
			</variables>
			<variables name="ClimateControl2Alarm" typeName="BOOL">
				<comment>TRUE = Alarm</comment>
			</variables>
			<variables name="ClimateControl3Alarm" typeName="BOOL">
				<comment>TRUE = Alarm</comment>
			</variables>
			<variables name="ClimateControl4Alarm" typeName="BOOL">
				<comment>TRUE = Alarm</comment>
			</variables>
			<variables name="PowerSupplyOK" typeName="BOOL">
				<comment>TRUE = OK</comment>
			</variables>
			<variables name="PowerSupplyLoadWarning" typeName="BOOL">
				<comment>TRUE = Load Warning (&gt; 90% of capacity)</comment>
			</variables>
			<variables name="PowerSupplyVoltageWarning" typeName="BOOL">
				<comment>TRUE = Voltage Warning (&lt; 10% of set value)</comment>
			</variables>
			<variables name="PowerSupplyBoostActive" typeName="BOOL">
				<comment>TRUE = Active</comment>
			</variables>
			<variables name="Transformer1OK" typeName="BOOL">
				<comment>TRUE = Alarm</comment>
			</variables>
			<variables name="Transformer2OK" typeName="BOOL">
				<comment>TRUE = Alarm</comment>
			</variables>
			<variables name="Transformer3OK" typeName="BOOL">
				<comment>TRUE = Alarm</comment>
			</variables>
			<variables name="Transformer4OK" typeName="BOOL">
				<comment>TRUE = Alarm</comment>
			</variables>
			<variables name="ClosedDoor1" typeName="BOOL">
				<comment>TRUE = Door is closed</comment>
			</variables>
			<variables name="ClosedDoor2" typeName="BOOL">
				<comment>TRUE = Door is closed</comment>
