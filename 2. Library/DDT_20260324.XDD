	<DDTSource DDTName="ATV9xx_ST_DDT" version="0.03" dateTime="dt#2018-03-06-14:44:14">
		<comment>ATV9xx primary information from/to HMI (Read/Write)</comment>
		<attribute name="TypeSignatureCheckSumString" value="CA8A"></attribute>
		<structure>
			<variables name="STW" typeName="WORD">
				<comment>Device main status.(bit 0 - Unknown state, bit 1- Not Ready, bit 2 - Running, bit 3 - Device Fail, bit 4 - Warning, bit 5 - Communication Fail, bit 6 - Necesary Reseting, bit 7 - Externally controlled, bit 8 - Reseting, bit 9 -EnableDFB, bit 15 - FowardReverseRotation)</comment>
			</variables>
			<variables name="CFGW" typeName="WORD">
				<comment>Device main control orders. Owner =1 HMI control (write), Owner= 0 information from inputs (read) . (bit 0 - ResetFail, bit 1 - Owner, bit 3 - Direction, bit 4 - QuickStop, bit 5 - EnableDevice, bit 6 - Run, bit 7 - ControlCommand, bit 8 - ControlSetpoint)</comment>
			</variables>
			<variables name="PresentValue" typeName="REAL">
				<comment>Present speed measured in user units</comment>
			</variables>
			<variables name="SetPoint" typeName="REAL">
				<comment>Requested speed setpoint measured in user units. Owner =1 HMI control (write), Owner= 0 information from setpoint input (read)</comment>
			</variables>
			<variables name="TorqueSetPoint" typeName="REAL">
				<comment>Requested torque setpoint measured in user %. Owner =1 HMI control (write), Owner= 0 information from TorqueSetpoint input (read)</comment>
			</variables>
		</structure>
	</DDTSource>
