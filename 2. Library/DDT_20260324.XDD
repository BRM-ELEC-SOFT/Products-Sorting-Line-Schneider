	<DDTSource DDTName="udtStorage_Manager" version="0.18" dateTime="dt#2026-01-19-03:44:48">
		<attribute name="TypeSignatureCheckSumString" value="E354"></attribute>
		<structure>
			<variables name="Status" typeName="INT">
				<comment>Status of the Storage location, status can be independend from the Line Manager, or Storage location will follow Line Manager status (copies it)</comment>
			</variables>
			<variables name="PausedByBunker" typeName="BOOL">
				<comment>TRUE = This storage location is paused by a bunker</comment>
			</variables>
			<variables name="Request_StartClaxon" typeName="BOOL">
				<comment>Bit that can be used to Turn on Start Claxon</comment>
			</variables>
			<variables name="SetManualControl" typeName="BOOL">
				<comment>TRUE = Set this location for manual control (independend from Line Manager)</comment>
			</variables>
			<variables name="EnableStorageLocation" typeName="BOOL">
				<comment>TRUE = Enable this location to be able to run (independently from Line Manager)</comment>
			</variables>
			<variables name="Reset_NumberOfBalesReady" typeName="BOOL">
				<comment>TRUE = Reset data of all baler locations</comment>
			</variables>
			<variables name="OutputFront_FlowTo_Location" typeName="ARRAY[0..4] OF BOOL">
				<comment>Set bit that flow needs to go to Baler location x, meaning of Forward conveyors: Flow[1] = Baler[1], etc.</comment>
			</variables>
			<variables name="OutputBack_FlowTo_Location" typeName="ARRAY[0..4] OF BOOL">
				<comment>Set bit that flow needs to go to Baler location x, meaning of Reverse conveyors: Flow[1] = Baler[1], etc.</comment>
			</variables>
			<variables name="OutputFront_Overrule_Location" typeName="ARRAY[0..4] OF BOOL">
				<comment>Set bit of Baler location x that it's ReadyForFeed signal is overruled, meaning Conveyors will forward material and ignore baler status, Overrules[1] = Baler[1] is ignored</comment>
			</variables>
			<variables name="OutputBack_Overrule_Location" typeName="ARRAY[0..4] OF BOOL">
				<comment>Set bit of Baler location x that it's ReadyForFeed signal is overruled, meaning Conveyors will forward material and ignore baler status, Overrules[1] = Baler[1] is ignored</comment>
			</variables>
			<variables name="OutputFront_Location1_RunDirectionConveyor" typeName="ARRAY[0..4] OF BOOL">
				<comment>TRUE = Run Conveyor Reverse when in Auto mode, FALSE = Run Forward</comment>
			</variables>
			<variables name="OutputFront_Location2_RunDirectionConveyor" typeName="ARRAY[0..4] OF BOOL">
				<comment>TRUE = Run Conveyor Reverse when in Auto mode, FALSE = Run Forward</comment>
			</variables>
			<variables name="OutputFront_Location3_RunDirectionConveyor" typeName="ARRAY[0..4] OF BOOL">
				<comment>TRUE = Run Conveyor Reverse when in Auto mode, FALSE = Run Forward</comment>
			</variables>
			<variables name="OutputFront_Location4_RunDirectionConveyor" typeName="ARRAY[0..4] OF BOOL">
				<comment>TRUE = Run Conveyor Reverse when in Auto mode, FALSE = Run Forward</comment>
			</variables>
			<variables name="OutputBack_Location1_RunDirectionConveyor" typeName="ARRAY[0..4] OF BOOL">
				<comment>TRUE = Run Conveyor Reverse when in Auto mode, FALSE = Run Forward</comment>
			</variables>
			<variables name="OutputBack_Location2_RunDirectionConveyor" typeName="ARRAY[0..4] OF BOOL">
				<comment>TRUE = Run Conveyor Reverse when in Auto mode, FALSE = Run Forward</comment>
			</variables>
			<variables name="OutputBack_Location3_RunDirectionConveyor" typeName="ARRAY[0..4] OF BOOL">
				<comment>TRUE = Run Conveyor Reverse when in Auto mode, FALSE = Run Forward</comment>
			</variables>
			<variables name="OutputBack_Location4_RunDirectionConveyor" typeName="ARRAY[0..4] OF BOOL">
				<comment>TRUE = Run Conveyor Reverse when in Auto mode, FALSE = Run Forward</comment>
			</variables>
			<variables name="NumberOfBalesReady_Baler" typeName="ARRAY[0..4] OF DINT">
				<comment>Display or keep track of number of bales produced</comment>
			</variables>
		</structure>
	</DDTSource>
