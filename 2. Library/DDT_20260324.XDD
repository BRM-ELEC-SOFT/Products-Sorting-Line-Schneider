	<DDTSource DDTName="udtStorage_Object_Parameters" version="0.07" dateTime="dt#2025-10-22-14:54:55">
		<attribute name="TypeSignatureCheckSumString" value="1878"></attribute>
		<structure>
			<variables name="SlowSpeed" typeName="INT"></variables>
			<variables name="NormalSpeed" typeName="INT"></variables>
			<variables name="TimeOverfull" typeName="DINT"></variables>
			<variables name="TimeOverfullOnEmptying" typeName="DINT"></variables>
			<variables name="TimeJogOnOverfull" typeName="DINT"></variables>
			<variables name="TimeDelaySensor" typeName="DINT"></variables>
			<variables name="TimeJog" typeName="DINT">
				<comment>Time for conveyor jog when fill level is nearing full in auto mode, this value makes that jog holds run signal a bit longer</comment>
			</variables>
			<variables name="TimeDoorOpen" typeName="DINT">
				<comment>Time for when Door Forward/Reverse is going Opening, when closing takes longer than this time, alarm will be activated</comment>
			</variables>
			<variables name="TimeDoorClose" typeName="DINT">
				<comment>Time for when Door Forward/Reverse is going Close, when closing takes longer than this time, alarm will be activated</comment>
			</variables>
			<variables name="TimeDoorRetry" typeName="DINT">
				<comment>Time for when Door Forward/Reverse failed to Open/Close, this retry time will then be added toTimeDoorOpen/TimeDoorClose</comment>
			</variables>
			<variables name="TimeDoorNoSensor" typeName="DINT">
				<comment>Time for when no Door Forward/Reverse Open Sensor is present, how long needs the door to go opened</comment>
			</variables>
			<variables name="RetriesDoorClose" typeName="INT"></variables>
			<variables name="Group" typeName="INT">
				<comment>Groups of bunkers that can open at the same time (if they are in same group)</comment>
			</variables>
			<variables name="PauseLineOnFull" typeName="BOOL">
				<comment>Pause Line when bunker is full (Overfull)</comment>
			</variables>
			<variables name="TwoWayOutput" typeName="BOOL">
				<comment>IF true, the output belt can go to two balers</comment>
			</variables>
			<variables name="Offline" typeName="BOOL">
				<comment>TRUE = Storage Object and its connected Objects (Conveyor/ChainHoist) are set Offline (not present)</comment>
			</variables>
		</structure>
	</DDTSource>
