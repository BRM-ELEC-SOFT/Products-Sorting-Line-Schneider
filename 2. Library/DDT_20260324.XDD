	<DDTSource DDTName="udtObject_Data_Sensors" version="0.05" dateTime="dt#2025-11-25-12:00:41">
		<comment>Contianer of sensor data being tripped, can be used for visual indications on HMI or diagnose</comment>
		<attribute name="TypeSignatureCheckSumString" value="FAC0"></attribute>
		<structure>
			<variables name="RotationOK" typeName="BOOL">
				<comment>TRUE = Rotation is detected, when monitoring of rotation is used an alarm will be given (when signal = FALSE)</comment>
			</variables>
			<variables name="TrackingOK" typeName="BOOL">
				<comment>TRUE = Tracking sensor detects track within tolerance, when monitoring of tracking is used an alarm will be given (when signal = FALSE)</comment>
			</variables>
			<variables name="FallPlateOK" typeName="BOOL">
				<comment>TRUE = Fall plate sensor is triggered, often used for Optical Sorters or Screens (can also be used for other applications)</comment>
			</variables>
			<variables name="MaterialFullOK" typeName="BOOL">
				<comment>TRUE = OK, FALSE = Full signal (after time filter), signals an alarm (Error) that this Object cannot accept anymore feed (Object can be; Compactor, Perforator, Belt with a sensor, etc.)</comment>
			</variables>
			<variables name="MaterialAlmostFullOK" typeName="BOOL">
				<comment>TRUE = OK, FALSE = Almost full signal (after time filter), signals an alarm (Warning) that this Object is nearly full (Object can be; Compactor, Perforator, Belt with a sensor, etc.)</comment>
			</variables>
			<variables name="VibrationOK" typeName="BOOL">
				<comment>TRUE = OK, FALSE = Almost full signal (after time filter), signals an alarm (Warning) that this Object is nearly full (Object can be; Compactor, Perforator, Belt with a sensor, etc.)</comment>
			</variables>
		</structure>
	</DDTSource>
