				<attribute name="ExtractBit" value="8"></attribute>
				<attribute name="RequestAccessRight" value="1"></attribute>
				<attribute name="InstancesProgramAccessRight" value="1"></attribute>
			</variables>
			<variables name="NTP_SERVER" typeName="BOOL">
				<comment>0: service not operating normally / 1: service operating normally or disabled</comment>
				<attribute name="IsVariableHidden" value="-1"></attribute>
				<attribute name="ExtractBit" value="9"></attribute>
				<attribute name="RequestAccessRight" value="1"></attribute>
				<attribute name="InstancesProgramAccessRight" value="1"></attribute>
			</variables>
			<variables name="SNTP_CLIENT" typeName="BOOL">
				<comment>0: service not operating normally / 1: service operating normally or disabled</comment>
				<attribute name="ExtractBit" value="10"></attribute>
				<attribute name="RequestAccessRight" value="1"></attribute>
