	<DDTSource DDTName="sdtSafety" version="0.08" dateTime="dt#2025-03-28-10:58:01">
		<comment>General struct that contains safety data, but is not actual safety variables (only signalling)</comment>
		<attribute name="IsTypeSafe" value="TRUE"></attribute>
		<attribute name="TypeSignatureCheckSumString" value="F78A"></attribute>
		<structure>
			<variables name="OK" typeName="BOOL">
				<comment>TRUE = Safety signal is okay</comment>
			</variables>
			<variables name="AlarmSignal" typeName="BOOL">
				<comment>TRUE = Safety Signal Alarm (Goes low when OK)</comment>
			</variables>
			<variables name="AlarmDiscrepancy" typeName="BOOL">
				<comment>TRUE = Safety Discrepancy Alarm (Goes low when discrepancy is OK)</comment>
			</variables>
			<variables name="AlarmReset" typeName="BOOL">
				<comment>TRUE = Reset attempt was executed while not allowed thus indicate alarm, alarm will be TRUE for xxx amount of time</comment>
			</variables>
			<variables name="ResetAllowed" typeName="BOOL">
				<comment>TRUE = Reset is possible, when OK = TRUE then this signal goes FALSE (since there is nothing to reset)</comment>
			</variables>
			<variables name="TriggerCount" typeName="INT">
				<comment>Value how many times safety device is triggered (EStop button pressed, or Doorswitch triggered)</comment>
			</variables>
		</structure>
	</DDTSource>
