	<DDTSource DDTName="udtObject_Settings_Parameters" version="0.06" dateTime="dt#2026-03-16-06:25:10">
		<attribute name="TypeSignatureCheckSumString" value="F9B2"></attribute>
		<structure>
			<variables name="StartAtSystemStart" typeName="BOOL">
				<comment>Object starts up immediately when line (safe) starts</comment>
			</variables>
			<variables name="NoStopOnPause" typeName="BOOL">
				<comment>Object does not stop when line pauses</comment>
			</variables>
			<variables name="ContinueFeedOnError" typeName="BOOL">
				<comment>When the object is in error, feeding may continue</comment>
			</variables>
			<variables name="FeedDelay" typeName="DINT">
				<comment>Feed delay in miliseconds (ms), used to provide next object with ON signal that it can start in flowchart</comment>
			</variables>
			<variables name="OffDelay" typeName="DINT">
				<comment>Off delay in miliseconds (ms), used to provide next object with OFF signal that it can stop in flowchart</comment>
			</variables>
			<variables name="InvertDirection" typeName="BOOL">
				<comment>Object will runs in reverse, or starts reversed</comment>
			</variables>
			<variables name="Offline" typeName="BOOL">
				<comment>Object will be offline in Auto (disabeld, alarms supressed)</comment>
			</variables>
			<variables name="Mode" typeName="INT">
				<comment>Set the mode of the object, if Object = OS for example, then material recipe can be selected (1 = Material 1, 2 = Material 2, etc.)</comment>
			</variables>
		</structure>
	</DDTSource>
