	<DDTSource DDTName="udtObject_Alarms_Extended" version="0.26" dateTime="dt#2026-01-31-06:52:53">
		<attribute name="TypeSignatureCheckSumString" value="BD6C"></attribute>
		<structure>
			<variables name="Summary" typeName="udtAlarmSummary"></variables>
			<variables name="AllOK" typeName="udtAlarm">
				<comment>TRUE = Condition AllOK is not OK (has alarm), this alarm can be anything, but most likely it is an Safety trigger</comment>
			</variables>
			<variables name="EStop" typeName="udtAlarm">
				<comment>TRUE = EStop is pressed at this object, handling is propely done in safety program, but information and object handling has to be adjusted accordingly</comment>
			</variables>
			<variables name="EStop_Discrepency" typeName="udtAlarm">
				<comment>TRUE = EStop has a discrepency (one of the 2 signals doens't match other logic level). Triggers safety and handling is done in safety program</comment>
			</variables>
			<variables name="EDoor" typeName="udtAlarm">
				<comment>TRUE = EDoor has been openend at this object, object will stop. Altough it's a safety signal, this signal might not stop the whole plant</comment>
			</variables>
			<variables name="EDoor_Discrepency" typeName="udtAlarm">
				<comment>TRUE = EDoor has a discrepency (one of the 2 signals doens't match other logic level). Triggers safety and handling is done in safety program</comment>
			</variables>
			<variables name="WorkSwitch" typeName="udtAlarm">
				<comment>TRUE = Object has work switch, which might trigger a Warning, Error or Safety </comment>
			</variables>
			<variables name="Rotation" typeName="udtAlarm">
				<comment>TRUE = Object has rotation alarm, which might trigger a Warning, Error or Safety </comment>
			</variables>
			<variables name="Tracking" typeName="udtAlarm">
				<comment>TRUE = Object has tracking alarm, which might trigger a Warning, Error or Safety </comment>
			</variables>
			<variables name="Breaker" typeName="udtAlarm">
				<comment>TRUE = Object has breaker alarm, which might trigger a Warning, Error or Safety </comment>
			</variables>
			<variables name="ExternalError" typeName="udtAlarm">
				<comment>TRUE = Object has External alarm, which might trigger a Warning, Error or Safety </comment>
			</variables>
			<variables name="ExternalWarning" typeName="udtAlarm">
				<comment>TRUE = Object has thermal alarm, which might trigger a Warning, Error or Safety </comment>
			</variables>
			<variables name="Sorting" typeName="udtAlarm">
				<comment>TRUE = Object hasexternal sorter alarm, which might trigger a Warning, Error or Safety </comment>
			</variables>
			<variables name="NoPower" typeName="udtAlarm">
				<comment>TRUE = Object has breaker alarm, which might trigger a Warning, Error or Safety </comment>
			</variables>
			<variables name="FallPlate" typeName="udtAlarm">
				<comment>TRUE = Object has Fall Plate alarm, which might trigger a Warning, Error or Safety </comment>
			</variables>
			<variables name="MaterialFull" typeName="udtAlarm">
				<comment>TRUE = Object has Material Full alarm, which might trigger a Warning, Error or Safety </comment>
			</variables>
			<variables name="MaterialAlmostFull" typeName="udtAlarm">
				<comment>TRUE = Object has Material Almost Full alarm, which might trigger a Warning, Error or Safety </comment>
			</variables>
			<variables name="AliveBit" typeName="udtAlarm">
				<comment>TRUE = Object has Alive Bit alarm, which might trigger a Warning, Error or Safety </comment>
			</variables>
			<variables name="Overrules" typeName="udtAlarm">
				<comment>TRUE = Object has a motor overrule active, only indication </comment>
			</variables>
			<variables name="Vibration" typeName="udtAlarm">
				<comment>TRUE = Object has a Vibration Alarm active</comment>
			</variables>
		</structure>
	</DDTSource>
