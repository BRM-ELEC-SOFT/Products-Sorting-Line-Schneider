	<DDTSource DDTName="udtUserManagement" version="0.02" dateTime="dt#2026-02-12-09:10:39">
		<comment>A special udt, meant to facilitate NON-HMI related accounts, think about settings taht should not be viewable for the "customer"</comment>
		<attribute name="TypeSignatureCheckSumString" value="79EB"></attribute>
		<structure>
			<variables name="User" typeName="string[12]"></variables>
			<variables name="Password" typeName="string[12]"></variables>
			<variables name="Login" typeName="BOOL">
				<comment>TRUE = Try to login with given username and password</comment>
			</variables>
			<variables name="Logoff" typeName="BOOL">
				<comment>TRUE = Try to loggoff, reset username and password</comment>
			</variables>
			<variables name="Denied" typeName="BOOL">
				<comment>TRUE = Login failed, try again</comment>
