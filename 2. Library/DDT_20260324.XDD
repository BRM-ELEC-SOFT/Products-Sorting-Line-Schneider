	<DDTSource DDTName="ATV9xxStatus" version="0.02" dateTime="dt#2018-03-06-14:44:16">
		<comment>Device status. Data from register ETA (W8603), (W8441) &amp; (8442)</comment>
		<attribute name="TypeSignatureCheckSumString" value="EBAB"></attribute>
		<structure>
			<variables name="ReadyToSwitchOn" typeName="BOOL">
				<comment>DSP402 device states. (W8603.0)</comment>
			</variables>
			<variables name="SwitchedOn" typeName="BOOL">
				<comment>DSP402 device states. (W8603.1)</comment>
			</variables>
			<variables name="OperationEnabled" typeName="BOOL">
				<comment>DSP402 device states. (W8603.2)</comment>
			</variables>
			<variables name="Malfunction" typeName="BOOL">
				<comment>Error present on the device (W8603.3)</comment>
			</variables>
			<variables name="VoltageEnabled" typeName="BOOL">
				<comment>Power section line supply present (Not W8603.4)</comment>
			</variables>
			<variables name="QuickStop" typeName="BOOL">
				<comment>QuickStop active (Not W8603.5)</comment>
			</variables>
			<variables name="SwitchOnDisabled" typeName="BOOL">
				<comment>DSP402 device states (W8603.6)</comment>
			</variables>
			<variables name="Alarm" typeName="BOOL">
				<comment>Alarm present on the device (W8603.7)</comment>
			</variables>
			<variables name="ForcedLocalMode" typeName="BOOL">
				<comment>Device controlled by the physical inputs (W8603.9)</comment>
			</variables>
			<variables name="ReferenceReached" typeName="BOOL">
				<comment>Rrequested setpoint has been reached by the inverter  (W8603.10)</comment>
			</variables>
			<variables name="ReferenceExceeded" typeName="BOOL">
				<comment>Requested setpoint has been exceeded by the inverter (W8603.11)</comment>
			</variables>
			<variables name="StopImposed" typeName="BOOL">
				<comment>Stop set by the remote STOP key (W8603.14)</comment>
			</variables>
			<variables name="ForwardReverseRotation" typeName="BOOL">
				<comment>Current inverter direction (Not W8603.15)</comment>
			</variables>
			<variables name="ReservedReferenceChannel" typeName="BOOL">
