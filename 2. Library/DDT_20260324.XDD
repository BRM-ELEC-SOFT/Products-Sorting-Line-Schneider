	<DDTSource DDTName="udtObject_Constants" version="0.13" dateTime="dt#2026-01-20-15:59:19">
		<attribute name="TypeSignatureCheckSumString" value="1418"></attribute>
		<structure>
			<variables name="SafeStart" typeName="INT">
				<comment>Status when a object is starting</comment>
			</variables>
			<variables name="Restart" typeName="INT">
				<comment>Status when a object is restarting, from pause</comment>
			</variables>
			<variables name="Cleaning" typeName="INT">
				<comment>Status when a object cleaning mode is active</comment>
			</variables>
			<variables name="Manual" typeName="INT">
				<comment>Status when a object is set in manual mode</comment>
			</variables>
			<variables name="JogForward" typeName="INT">
				<comment>Status when a object is set in Jog Forward</comment>
			</variables>
			<variables name="JogReverse" typeName="INT">
				<comment>Status when a object is set in Jog Reverse</comment>
			</variables>
			<variables name="ManualForward" typeName="INT">
				<comment>Status when a object is manually going forward (from status cObjectManual)</comment>
			</variables>
			<variables name="ManualReverse" typeName="INT">
				<comment>Status when a object is manually going reversed (from status cObjectManual)</comment>
			</variables>
			<variables name="WarningStillReady" typeName="INT">
				<comment>Status when a object is still ready to start because it only has a warning, but might be stopped in the future</comment>
			</variables>
			<variables name="ErrorNotReady" typeName="INT">
				<comment>Status when a object is not ready to start because of an Error</comment>
			</variables>
			<variables name="Starting_Forward" typeName="INT">
				<comment>Status when a object is starting</comment>
			</variables>
			<variables name="Starting_Reverse" typeName="INT"></variables>
			<variables name="Running_Forward" typeName="INT">
				<comment>Status when a object is running (active with feed)</comment>
			</variables>
			<variables name="Running_Reverse" typeName="INT"></variables>
			<variables name="WaitingStop_Forward" typeName="INT">
				<comment>Status when a object is waiting to stop (other object is feeding this status object)</comment>
			</variables>
			<variables name="WaitingStop_Reverse" typeName="INT"></variables>
			<variables name="CanStop_Forward" typeName="INT">
				<comment>Status when a object is signalling it can stop</comment>
			</variables>
			<variables name="CanStop_Reverse" typeName="INT"></variables>
			<variables name="LineErrorQuickStop" typeName="INT">
				<comment>Status when a object has to stop immediatly (not waiting for other object feed to go FALSE)</comment>
			</variables>
			<variables name="Paused" typeName="INT">
				<comment>Status when a object line is paused</comment>
			</variables>
			<variables name="NextObjectPaused" typeName="INT">
				<comment>Status when a next object is in pause (object that gets feed from instance object)</comment>
			</variables>
			<variables name="Error" typeName="INT"></variables>
			<variables name="ErrorContinue" typeName="INT">
				<comment>Status when a object cannot stop when line or objects before pause (setting in object)</comment>
			</variables>
			<variables name="NoStopOnPause_Forward" typeName="INT">
				<comment>Status when object pause is activated, continue to run Forward</comment>
			</variables>
			<variables name="NoStopOnPause_Reverse" typeName="INT">
				<comment>Status when object pause is activated, continue to run Reverse</comment>
			</variables>
			<variables name="DoorOpen" typeName="INT">
				<comment>Status when a object door is open</comment>
			</variables>
			<variables name="EStop" typeName="INT">
				<comment>Status when a object EStop is triggered / pressed</comment>
			</variables>
			<variables name="Offline" typeName="INT">
				<comment>Status when a object is set offline (setting in object)</comment>
			</variables>
			<variables name="Stopped" typeName="INT">
				<comment>Status when a object is stopped</comment>
			</variables>
		</structure>
	</DDTSource>
