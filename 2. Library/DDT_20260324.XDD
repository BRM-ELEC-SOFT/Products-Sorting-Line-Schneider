	<DDTSource DDTName="udtStorage_Object_Config" version="0.12" dateTime="dt#2025-10-22-14:54:53">
		<attribute name="TypeSignatureCheckSumString" value="0FE6"></attribute>
		<structure>
			<variables name="Name" typeName="string[10]">
				<comment>Name of the Storage Container</comment>
			</variables>
			<variables name="NameDoorForward" typeName="string[10]">
				<comment>Name of the Forward door Baler</comment>
			</variables>
			<variables name="NameDoorReverse" typeName="string[10]">
				<comment>Name of the Reverse door Baler</comment>
			</variables>
			<variables name="Description" typeName="string[20]">
				<comment>Description of the Storage Container</comment>
			</variables>
			<variables name="StorageType" typeName="INT">
				<comment>Type 0 = Storage Container VFD, 1 = SC with starters, 2 = Fixed bin (has already Middle sensor)</comment>
			</variables>
			<variables name="NoDoor" typeName="BOOL">
				<comment>If no door is available</comment>
			</variables>
			<variables name="HasSensorTopForward" typeName="BOOL">
				<comment>TRUE = Sensor is present for Forward Top (Filling)</comment>
			</variables>
			<variables name="HasSensorTopReverse" typeName="BOOL">
				<comment>TRUE = Sensor is present for Reverse Top (Filling)</comment>
			</variables>
			<variables name="HasSensorBotForward" typeName="BOOL">
				<comment>TRUE = Sensor is present for Forward Bot (Filling)</comment>
			</variables>
			<variables name="HasSensorBotReverse" typeName="BOOL">
				<comment>TRUE = Sensor is present for Reverse Bot (Filling)</comment>
			</variables>
			<variables name="HasSensorOpenForward" typeName="BOOL">
				<comment>TRUE = Sensor is present for Door Forward Open (Door)</comment>
			</variables>
			<variables name="HasSensorOpenReverse" typeName="BOOL">
				<comment>TRUE = Sensor is present for Door Reverse Open (Door)</comment>
			</variables>
			<variables name="NoHMIAlarms" typeName="BOOL">
				<comment>TRUE = Disable HMI alarms, but alarms will still be present/active in the program</comment>
			</variables>
			<variables name="OutputToForward" typeName="BOOL">
				<comment>TRUE = Storage Object can output its material forward (has Chain Hoist Forward)</comment>
			</variables>
			<variables name="OutputToReverse" typeName="BOOL">
				<comment>TRUE = Storage Object can output its material reverse (has Chain Hoist Reverse)</comment>
			</variables>
			<variables name="FillDirection_Reverse" typeName="BOOL">
				<comment>TRUE = Filling direction is set to Reverse</comment>
			</variables>
		</structure>
	</DDTSource>
