	<DDTSource DDTName="udtOverrules" version="0.29" dateTime="dt#2026-02-12-05:57:34">
		<attribute name="TypeSignatureCheckSumString" value="51E9"></attribute>
		<structure>
			<variables name="SimulationActive" typeName="BOOL">
				<comment>TRUE = Overrule all "error" signals in objects or others. Simulates functional behaviour of objects and others</comment>
			</variables>
			<variables name="CommissioningActive" typeName="BOOL">
				<comment>TRUE = Overrule motor signals, like feedback, ready or others. This is to commission the line (FAT or other)</comment>
			</variables>
			<variables name="IgnoreRotations" typeName="BOOL">
				<comment>TRUE = Overrule rotation measurement (if configured in settings to be enabled)</comment>
			</variables>
			<variables name="DriveOnline" typeName="BOOL">
				<comment>TRUE = Overrule Drive Online signal</comment>
			</variables>
			<variables name="Claxon" typeName="BOOL">
				<comment>TRUE = Overrule startup claxon, skips claxon time activated when starting</comment>
			</variables>
			<variables name="Warnings" typeName="BOOL">
				<comment>TRUE = Overrule Warning signals, service hours, work-switch or others are set OK </comment>
			</variables>
			<variables name="Errors" typeName="BOOL">
				<comment>TRUE = Overrule Error signals, so motor ready signals are set (breaker or other motor protection is set OK)</comment>
			</variables>
			<variables name="EDoors" typeName="BOOL">
				<comment>TRUE = Overrule EDoor signals on objects</comment>
			</variables>
			<variables name="EStops" typeName="BOOL">
				<comment>TRUE = Overrule EStops signals on objects</comment>
			</variables>
			<variables name="Hardware" typeName="BOOL">
				<comment>TRUE = Overrule hardware alarms, whem motor has hardware error (like DOL), skips alarms</comment>
			</variables>
			<variables name="Locks" typeName="BOOL">
				<comment>TRUE = Overrule MCC Lock(s) alarms, overrule used in LineManager </comment>
			</variables>
			<variables name="Storage" typeName="BOOL">
				<comment>TRUE = Overrule Storage Overfull condition, Line will not be paused </comment>
			</variables>
			<variables name="SimulateError" typeName="BOOL">
				<comment>TRUE = Simulation of an error, after 20 seconds if line is running in auto, the error output will be set high</comment>
			</variables>
			<variables name="RemoteStop" typeName="BOOL">
				<comment>TRUE = Overrules RIO's Stop button, can be useful for FAT's, when RIO's in project are not present (in network)</comment>
			</variables>
			<variables name="SetObjectDefaultSpeeds" typeName="BOOL">
				<comment>TRUE = Set default speed of 1000 rpm on all objects</comment>
			</variables>
			<variables name="NoHMIAlarms" typeName="BOOL">
				<comment>TRUE = Suppress all HMI alarms</comment>
			</variables>
			<variables name="NoClaxon" typeName="BOOL">
				<comment>TRUE = Suppress Claxon signals (Start + Alarm)</comment>
			</variables>
			<variables name="TestIndicators" typeName="BOOL">
				<comment>TRUE = Make outputs connected to indicators, beacons or lamps HIGH (TRUE)</comment>
			</variables>
			<variables name="TestClaxonStart" typeName="BOOL">
				<comment>TRUE = Make outputs connected to claxon start tone HIGH (TRUE)</comment>
			</variables>
			<variables name="TestClaxonAlarm" typeName="BOOL">
				<comment>TRUE = Make outputs connected to claxon alarm tone HIGH (TRUE)</comment>
			</variables>
			<variables name="TestHMIAlarms" typeName="BOOL">
				<comment>TRUE = Set all Object / Storage / MCC / Motor alarms to TRUE, does not internally trigger alarms, but normal alarm functionality remains </comment>
			</variables>
			<variables name="TestCommunicationInputs" typeName="BOOL">
				<comment>TRUE = Disable inputs received from communication channels (like ethernet IP devices/DTM's), so programmer can set in animation table bits TRUE or FALSE or other</comment>
			</variables>
			<variables name="TestCommunicationOutputs" typeName="BOOL">
				<comment>TRUE = Disable outputs received from communication channels (like ethernet IP devices/DTM's), so programmer can set in animation table bits TRUE or FALSE or other</comment>
			</variables>
			<variables name="ExternalSystem_MachineEx_Feedback" typeName="BOOL">
				<comment>TRUE = Set MachineEx feedback inputs for Flow chart start-stop procedure OK, start = Feedback, stop = No feedback (just as an example)</comment>
			</variables>
			<variables name="AddTimeMinimum_Feedback" typeName="DINT">
				<comment>Add time to minimum of the Feedback</comment>
			</variables>
			<variables name="AddTimeMaximum_Feedback" typeName="DINT">
				<comment>Add time to maximum of the Feedback</comment>
			</variables>
			<variables name="AddTimeMinimum_CurrentMeasurement" typeName="UINT">
				<comment>Add time to minimum of the Motor Current Measurement (Driver Error)</comment>
			</variables>
			<variables name="AddTimeMaximum_CurrentMeasurement" typeName="UINT">
				<comment>Add time to Maximum of the Motor Current Measurement (Driver Error)</comment>
			</variables>
			<variables name="SetStandardObjectSclaingValues" typeName="BOOL">
				<comment>TRUE = Set standard scaling values for measured data (no offset), so it will be standard 1</comment>
			</variables>
			<variables name="ResetStatistics" typeName="BOOL">
				<comment>TRUE = Reset all Statistics data</comment>
			</variables>
		</structure>
	</DDTSource>
