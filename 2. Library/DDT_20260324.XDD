	<DDTSource DDTName="udtObject_Inputs_Conditions" version="0.14" dateTime="dt#2025-11-25-12:00:49">
		<attribute name="TypeSignatureCheckSumString" value="3CB5"></attribute>
		<structure>
			<variables name="AllOK" typeName="BOOL">
				<comment>TRUE = No alarm is active that prevents object from starting, for example EStop, or others </comment>
			</variables>
			<variables name="MayRunOK" typeName="BOOL">
				<comment>TRUE = Object can run, extra condition to prevent object from starting</comment>
			</variables>
			<variables name="FeedbackOK" typeName="BOOL">
				<comment>TRUE = OK, if this input goes low during operation, this will trigger a feedback alarm</comment>
			</variables>
			<variables name="PowerOK" typeName="BOOL">
				<comment>TRUE = OK, Power can be applied to the motor (if run signal is given)</comment>
			</variables>
			<variables name="BreakerOK" typeName="BOOL">
				<comment>TRUE = Alarm, breaker alarm (too much current) is triggered and switched off</comment>
			</variables>
			<variables name="ThermalOK" typeName="BOOL">
				<comment>TRUE = Alarm, thermal alarm (too much current or motor is overheating) is triggered</comment>
			</variables>
			<variables name="ExternalOK" typeName="BOOL">
				<comment>TRUE = Alarm, externally there is an error active</comment>
			</variables>
			<variables name="ExternalWarning" typeName="BOOL">
				<comment>TRUE = Alarm, externally there is a warning active</comment>
			</variables>
			<variables name="ExternalInfo" typeName="STRING">
				<comment>Exrternal info string, if used or provided what the alarm specifies</comment>
			</variables>
			<variables name="FallplateOK" typeName="BOOL">
				<comment>TRUE = OK, Fall Plate is in the correct position</comment>
			</variables>
			<variables name="WorkSwitchOK" typeName="BOOL">
				<comment>TRUE = OK, workswitch in the correct position</comment>
			</variables>
			<variables name="TrackingOK" typeName="BOOL">
				<comment>TRUE = OK, tracking is operational (pulsing)</comment>
			</variables>
			<variables name="RotationOK" typeName="BOOL">
				<comment>TRUE = OK, rotation is operational (pulsing)</comment>
			</variables>
			<variables name="CurrentOK" typeName="BOOL">
				<comment>TRUE = OK, current is operational (measure current)</comment>
			</variables>
			<variables name="TemperatureOK" typeName="BOOL">
				<comment>TRUE = OK, temperature is within Error range (temperature is still OK)</comment>
			</variables>
			<variables name="PreTemperatureOK" typeName="BOOL">
				<comment>TRUE = OK, temperature is within Warning range (temperature is OK)</comment>
			</variables>
			<variables name="MaterialFullOK" typeName="BOOL">
				<comment>TRUE = OK, error sensor doens't detect material or ins't blocked (can be used for Drum feeder, Compactor, or other)</comment>
			</variables>
			<variables name="MaterialAlmostFullOK" typeName="BOOL">
				<comment>TRUE = OK, warning sensor doens't detect material or ins't blocked (can be used for Drum feeder Compactor, or other)</comment>
			</variables>
			<variables name="AliveBit" typeName="BOOL">
				<comment>TRUE = OK for 3 seconds, FALSE = OK for 3 seconds, needs constant switching signal to remain OK</comment>
			</variables>
			<variables name="VibrationOK" typeName="BOOL">
				<comment>TRUE = OK, Vibration is within limit range</comment>
			</variables>
		</structure>
	</DDTSource>
