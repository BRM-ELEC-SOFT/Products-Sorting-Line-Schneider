	<DDTSource DDTName="udtAlarm" version="0.12" dateTime="dt#2025-12-21-17:48:23">
		<attribute name="TypeSignatureCheckSumString" value="D863"></attribute>
		<structure>
			<variables name="Active" typeName="BOOL">
				<comment>TRUE = Alarm is active</comment>
			</variables>
			<variables name="ReadyToReset" typeName="BOOL">
				<comment>TRUE = Alarm is ready to be resetted, reset is allowed</comment>
			</variables>
			<variables name="InvalidReset" typeName="BOOL">
				<comment>TRUE = Alarm reset is attempted, but is rejected. Output stays TRUE for a limited amount of time</comment>
			</variables>
			<variables name="Acknowledged" typeName="BOOL">
				<comment>TRUE = Alarm is acknowledged by end-user, goes FALSE when Alarm = OK</comment>
			</variables>
			<variables name="Level" typeName="INT">
				<comment>Alarm level, 0 = nothing or no alarm, 1 = Emergency, 2 = Error, 3 = Discturbance, 4 = Warning, 5 = Other</comment>
			</variables>
			<variables name="Number" typeName="INT">
				<comment>Alarm number, to display correct text in correct language on HMI</comment>
			</variables>
			<variables name="Overruled" typeName="BOOL">
				<comment>TRUE = Alarm bad status is ignored</comment>
			</variables>
		</structure>
	</DDTSource>
