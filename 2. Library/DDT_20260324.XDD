	<DDTSource DDTName="udtObject_Settings_Config" version="0.23" dateTime="dt#2026-03-16-06:25:01">
		<attribute name="TypeSignatureCheckSumString" value="1A4C"></attribute>
		<structure>
			<variables name="MotorType" typeName="INT">
				<comment>0=VFD-FR, 1, VFD-F, 10=DOL-FR TeSys, 11=DOL-F TeSys, 12=DOL-FR Starter, 13=DOL-F Starter, 20 = SH, 21 = OPT, 22 = CP (Compactor), 23 = Perforator, 24 = Misc)</comment>
			</variables>
			<variables name="SpeedRPM" typeName="INT">
				<comment>Speed of the motor in rpm, used in Auto of the line (this is the speed setpoint of the unit in normal conditions)</comment>
			</variables>
			<variables name="PercentageRunning" typeName="INT">
				<comment>Percentage Object is running. 100(%) = Speed RPM, this changes RPM pf SpeedRPM</comment>
			</variables>
			<variables name="MinimumRPM" typeName="INT">
				<comment>Minimal Speed in RPM</comment>
			</variables>
			<variables name="MaximumRPM" typeName="INT">
				<comment>Maximal Speed in RPM</comment>
			</variables>
			<variables name="JogRPM" typeName="INT">
				<comment>Jog speed in RPM</comment>
			</variables>
			<variables name="RampUp" typeName="INT">
				<comment>Ramp up in seconds</comment>
			</variables>
			<variables name="RampDown" typeName="INT">
				<comment>Ramp down in seconds</comment>
			</variables>
			<variables name="PTxType" typeName="INT">
				<comment>0 = None, 1 = PTC, 2 = PT100, 3 = PT1000</comment>
			</variables>
			<variables name="ScalingRPM" typeName="REAL">
				<comment>Scaling value for RPM, this is applied in calculation conversion (assumed RPM * "this value")</comment>
			</variables>
			<variables name="ScalingFactorPower" typeName="REAL"></variables>
			<variables name="ScalingFactorCurrent" typeName="REAL"></variables>
			<variables name="ScalingSpeedToMeterSecond" typeName="REAL">
				<comment>Factor or scaling value from RPM to Meter/Second</comment>
			</variables>
			<variables name="FeedbackTimeStart" typeName="DINT">
				<comment>Time in miliseconds (ms) for Driver provides feedback that it is active (ON)</comment>
			</variables>
			<variables name="FeedbackTimeStop" typeName="DINT">
				<comment>Time in miliseconds (ms)  for Driver provides feedback that it is deactive (OFF)</comment>
			</variables>
			<variables name="CurrentMeasurementTime" typeName="UINT">
				<comment>Time in miliseconds (ms)  for Driver current measurement trip after xxx seconds no current has been measured</comment>
			</variables>
			<variables name="FreeWheelStop" typeName="BOOL">
				<comment>Free Wheel Stop aVFD.</comment>
			</variables>
			<variables name="AliveBit" typeName="BOOL">
				<comment>TRUE = Alive bit monitoring is enabled</comment>
			</variables>
			<variables name="PTxStopsObject" typeName="BOOL">
				<comment>TRUE = PTx trigger (over-temperature) generates Error-like Alarm</comment>
			</variables>
		</structure>
	</DDTSource>
