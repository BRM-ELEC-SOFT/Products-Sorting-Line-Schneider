	<DDTSource DDTName="MBEthClient1Data" version="1.02" dateTime="dt#2020-03-24-12:59:53">
		<comment>MBTCP Client Data</comment>
		<attribute name="TypeSignatureCheckSumString" value="1F7C"></attribute>
		<structure>
			<variables name="Data" typeName="ARRAY[0..125] OF INT">
				<comment>Data Buffer</comment>
			</variables>
			<variables name="IPAddress" typeName="string[20]">
				<comment>IPAddress of device in format '{IP1.IP2.IP3.IP4}'</comment>
			</variables>
			<variables name="ModBusID" typeName="string[20]">
				<comment>ModBusID</comment>
			</variables>
			<variables name="Length" typeName="UINT">
				<comment>Length of bytes of data to be sent</comment>
			</variables>
			<variables name="Priority" typeName="UINT">
				<comment>Priority of the request </comment>
			</variables>
			<variables name="ErrorCode" typeName="INT">
				<comment>Error Information</comment>
			</variables>
			<variables name="ErrorCode1" typeName="INT">
				<comment>Type of Error</comment>
			</variables>
			<variables name="Retries" typeName="INT">
				<comment>Number of Retries</comment>
			</variables>
			<variables name="Readlength" typeName="INT">
				<comment>Length of data received from port in bytes</comment>
			</variables>
			<variables name="OrderNumber" typeName="INT">
				<comment>Order Number of Request</comment>
			</variables>
			<variables name="Status" typeName="WORD">
				<comment>Status of Request of Client. 0 - Idle,  1- Client has sent data, 2 - Port is processing the request, 3 -Port has processed without error, 4 - Port has processed with error</comment>
			</variables>
			<variables name="ServiceID" typeName="BYTE">
				<comment>MBTCP ServiceID</comment>
			</variables>
			<variables name="ReadWrite" typeName="BOOL">
				<comment>0 = Read operation 1 = Write Operation</comment>
			</variables>
			<variables name="MemoryInput" typeName="BOOL">
				<comment>0 = Operation on Memory Type Register(%M) 1=  Operation on Input Type Register(%I)</comment>
			</variables>
			<variables name="RegisterAddress" typeName="UINT">
				<comment>The address of the Register on which operation to be performed</comment>
			</variables>
			<variables name="BitWord" typeName="BOOL">
				<comment>0= Operation on Bits (%I,%M), 1= Operation on Registers (%IW,%MW)</comment>
			</variables>
			<variables name="RWSimulatneous" typeName="BOOL">
				<comment>1= The opertation considered is read and write simultaneously in one request</comment>
			</variables>
			<variables name="RWReadLen" typeName="UINT">
				<comment>When RWBoth is 1 then length of Registers to read max 125</comment>
			</variables>
			<variables name="RWWriteLen" typeName="UINT">
				<comment>When RWBoth is 1 then length of Registers to write max 100</comment>
			</variables>
			<variables name="RWReadRegister" typeName="UINT">
				<comment>When RWBoth is 1 then address of starting Register to read</comment>
			</variables>
			<variables name="RWWriteRegister" typeName="UINT">
				<comment>When RWBoth is 1 then address of starting Register to write</comment>
			</variables>
		</structure>
	</DDTSource>
