	<DDTSource DDTName="udtStorage_Object_Buttons" version="0.11" dateTime="dt#2025-11-03-13:50:03">
		<attribute name="TypeSignatureCheckSumString" value="D37C"></attribute>
		<structure>
			<variables name="Forward" typeName="BOOL">
				<comment>TRUE = Material will go forward in normal operation mode</comment>
			</variables>
			<variables name="Reverse" typeName="BOOL">
				<comment>TRUE = Material will go reverse in normal operation mode</comment>
			</variables>
			<variables name="OverruleClose" typeName="BOOL">
				<comment>TRUE = Ignore closing signal status, sensor is being ignored and the container is considered to be closed</comment>
			</variables>
			<variables name="SetSlowSpeed" typeName="BOOL">
				<comment>TRUE = Set slow speed, uses value of Speed Slow</comment>
			</variables>
			<variables name="Conveyor_JogForward" typeName="BOOL">
				<comment>TRUE = Run Conveyor Forward, needs constant TRUE signal</comment>
			</variables>
			<variables name="Conveyor_JogReverse" typeName="BOOL">
				<comment>TRUE = Run Conveyor Reverse, needs constant TRUE signal</comment>
			</variables>
			<variables name="Retry" typeName="BOOL">
				<comment>TRUE = Failed Opening or Closing action will be reset (go to Idle and if Forward / Reverse is still selected try again)</comment>
			</variables>
		</structure>
	</DDTSource>
