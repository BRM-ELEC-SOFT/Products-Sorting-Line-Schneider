	<DDTSource DDTName="udtGeneralBase_Statistics" version="0.15" dateTime="dt#2026-03-10-12:09:01">
		<attribute name="TypeSignatureCheckSumString" value="3A5D"></attribute>
		<structure>
			<variables name="Reset_Data" typeName="BOOL">
				<comment>TRUE = Resets all data</comment>
			</variables>
			<variables name="TON_H" typeName="udtObject_EnergyDate"></variables>
			<variables name="Energy" typeName="udtObject_EnergyDate">
				<instanceElementDesc name="Hour">
					<comment>kWh</comment>
				</instanceElementDesc>
				<instanceElementDesc name="Day">
					<comment>MWh</comment>
				</instanceElementDesc>
				<instanceElementDesc name="Month">
					<comment>GWh</comment>
				</instanceElementDesc>
				<instanceElementDesc name="Year">
					<comment>TWh</comment>
				</instanceElementDesc>
				<instanceElementDesc name="MaximumValue_Hour">
					<comment>in kWh</comment>
				</instanceElementDesc>
				<instanceElementDesc name="MaximumValue_Day">
					<comment>In MWh</comment>
				</instanceElementDesc>
				<instanceElementDesc name="MaximumValue_Month">
					<comment>In GWh</comment>
				</instanceElementDesc>
				<instanceElementDesc name="MaximumValue_Year">
					<comment>In TWh</comment>
				</instanceElementDesc>
			</variables>
			<variables name="Efficiency" typeName="udtObject_EnergyDate"></variables>
			<variables name="Runtime" typeName="udtObject_RunningTime">
				<comment>Values in here are plant total runtime (not line specific)</comment>
			</variables>
			<variables name="Actual_TON_H" typeName="UINT">
				<comment>Actual TON per Hour value, in hours averaged</comment>
			</variables>
			<variables name="Actual_kWh" typeName="UINT">
				<comment>Actual kWh value, in hours averaged</comment>
			</variables>
			<variables name="Actual_Efficiency" typeName="UINT">
				<comment>Actual Efficiency value, in hours averaged using percentage (%)</comment>
			</variables>
			<variables name="Actual_Runtime" typeName="udtTime"></variables>
			<variables name="YearValueHMI" typeName="ARRAY[0..40] OF INT"></variables>
			<variables name="TON_H_Scale_Day" typeName="ARRAY[0..31] OF UINT">
				<comment>0 =TON/H, 1 = kTON/H, 2 = MTON/H</comment>
			</variables>
			<variables name="TON_H_Scale_Month" typeName="ARRAY[0..12] OF UINT">
				<comment>0 =TON/H, 1 = kTON/H, 2 = MTON/H</comment>
			</variables>
			<variables name="TON_H_Scale_Year" typeName="ARRAY[0..40] OF UINT">
				<comment>0 =TON/H, 1 = kTON/H, 2 = MTON/H</comment>
			</variables>
			<variables name="Energy_Scale_Day" typeName="ARRAY[0..31] OF UINT">
				<comment>0 =kWh, 1 = MWh, 2 = GWh, 3 = TWh</comment>
			</variables>
			<variables name="Energy_Scale_Month" typeName="ARRAY[0..12] OF UINT">
				<comment>0 =kWh, 1 = MWh, 2 = GWh, 3 = TWh</comment>
			</variables>
			<variables name="Energy_Scale_Year" typeName="ARRAY[0..40] OF UINT">
				<comment>0 =kWh, 1 = MWh, 2 = GWh, 3 = TWh</comment>
			</variables>
		</structure>
	</DDTSource>
