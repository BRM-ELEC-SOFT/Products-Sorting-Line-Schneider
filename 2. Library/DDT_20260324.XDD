	<DDTSource DDTName="T_BMENOC0301_4" version="1.00" dateTime="dt#2014-11-05-10:00:00">
		<comment>Device DDT For BME NOC Factory Cast</comment>
		<attribute name="IsTypeLocked" value="TRUE"></attribute>
		<attribute name="IsDeviceDDT" value="TRUE"></attribute>
		<attribute name="DeviceDDTKind" value="2#0000_0000"></attribute>
		<attribute name="TypeSignatureCheckSumString" value="9C8E"></attribute>
		<attribute name="IsHSBYExchange" value="FALSE"></attribute>
		<attribute name="IsTypeHiddenButExported" value="TRUE"></attribute>
		<structure>
			<variables name="ETH_STATUS" typeName="WORD">
				<comment>Ethernet status</comment>
				<attribute name="RequestAccessRight" value="1"></attribute>
				<attribute name="InstancesProgramAccessRight" value="1"></attribute>
			</variables>
			<variables name="PORT1_LINK" typeName="BOOL">
				<comment>Link up/down for Ethernet port 1</comment>
				<attribute name="ExtractBit" value="0"></attribute>
				<attribute name="RequestAccessRight" value="1"></attribute>
				<attribute name="InstancesProgramAccessRight" value="1"></attribute>
			</variables>
			<variables name="PORT2_LINK" typeName="BOOL">
				<comment>Link up/down for Ethernet port 2</comment>
				<attribute name="ExtractBit" value="1"></attribute>
				<attribute name="RequestAccessRight" value="1"></attribute>
				<attribute name="InstancesProgramAccessRight" value="1"></attribute>
			</variables>
			<variables name="PORT3_LINK" typeName="BOOL">
				<comment>Link up/down for Ethernet port 3</comment>
				<attribute name="ExtractBit" value="2"></attribute>
				<attribute name="RequestAccessRight" value="1"></attribute>
				<attribute name="InstancesProgramAccessRight" value="1"></attribute>
			</variables>
			<variables name="ETH_BKP_PORT_LINK" typeName="BOOL">
				<comment>Link up/down for Ethernet backplane port</comment>
				<attribute name="ExtractBit" value="3"></attribute>
				<attribute name="RequestAccessRight" value="1"></attribute>
				<attribute name="InstancesProgramAccessRight" value="1"></attribute>
			</variables>
			<variables name="HSBY_LINK" typeName="BOOL">
				<comment>Link up/down for HSBY port</comment>
				<attribute name="IsVariableHidden" value="-1"></attribute>
				<attribute name="ExtractBit" value="4"></attribute>
				<attribute name="RequestAccessRight" value="1"></attribute>
				<attribute name="InstancesProgramAccessRight" value="1"></attribute>
			</variables>
			<variables name="REDUNDANCY_STATUS" typeName="BOOL">
				<comment>Redundancy status / backup path available</comment>
				<attribute name="IsVariableHidden" value="-1"></attribute>
				<attribute name="ExtractBit" value="5"></attribute>
				<attribute name="RequestAccessRight" value="1"></attribute>
				<attribute name="InstancesProgramAccessRight" value="1"></attribute>
			</variables>
			<variables name="SCANNER_OK" typeName="BOOL">
				<comment>Scanner OK and scanning at least 1 equipment (if at least 1 equipment configured)</comment>
				<attribute name="ExtractBit" value="6"></attribute>
				<attribute name="RequestAccessRight" value="1"></attribute>
				<attribute name="InstancesProgramAccessRight" value="1"></attribute>
			</variables>
			<variables name="GLOBAL_STATUS" typeName="BOOL">
				<comment>0: one or more services not operating normally / 1: all operational</comment>
				<attribute name="ExtractBit" value="7"></attribute>
				<attribute name="RequestAccessRight" value="1"></attribute>
				<attribute name="InstancesProgramAccessRight" value="1"></attribute>
			</variables>
			<variables name="NETWORK_HEALTH" typeName="BOOL">
				<comment>1: No traffic overload detected / 0: Traffic overload detected (ex: broadcast storm). Check your network topology and configuration.</comment>
				<attribute name="ExtractBit" value="8"></attribute>
				<attribute name="RequestAccessRight" value="1"></attribute>
				<attribute name="InstancesProgramAccessRight" value="1"></attribute>
			</variables>
			<variables name="SERVICE_STATUS" typeName="WORD">
				<comment>One bit for each user-observable feature</comment>
				<attribute name="RequestAccessRight" value="1"></attribute>
				<attribute name="InstancesProgramAccessRight" value="1"></attribute>
			</variables>
			<variables name="RSTP_SERVICE" typeName="BOOL">
				<comment>0: service not operating normally / 1: service operating normally or disabled</comment>
				<attribute name="ExtractBit" value="0"></attribute>
				<attribute name="RequestAccessRight" value="1"></attribute>
				<attribute name="InstancesProgramAccessRight" value="1"></attribute>
			</variables>
			<variables name="PORT502_SERVICE" typeName="BOOL">
				<comment>0: service not operating normally / 1: service operating normally or disabled</comment>
				<attribute name="ExtractBit" value="2"></attribute>
				<attribute name="RequestAccessRight" value="1"></attribute>
				<attribute name="InstancesProgramAccessRight" value="1"></attribute>
			</variables>
			<variables name="SNMP_SERVICE" typeName="BOOL">
				<comment>0: service not operating normally / 1: service operating normally or disabled</comment>
				<attribute name="ExtractBit" value="3"></attribute>
				<attribute name="RequestAccessRight" value="1"></attribute>
				<attribute name="InstancesProgramAccessRight" value="1"></attribute>
			</variables>
			<variables name="MAIN_IP_ADDRESS_STATUS" typeName="BOOL">
				<comment>Main IP address status (0 in case of duplicate IP or no IP assigned)</comment>
				<attribute name="ExtractBit" value="4"></attribute>
				<attribute name="RequestAccessRight" value="1"></attribute>
				<attribute name="InstancesProgramAccessRight" value="1"></attribute>
			</variables>
			<variables name="ETH_BKP_FAILURE" typeName="BOOL">
				<comment>Ethernet backplane hardware status (0: failure, 1: OK)</comment>
				<attribute name="IsVariableHidden" value="-1"></attribute>
				<attribute name="ExtractBit" value="5"></attribute>
				<attribute name="RequestAccessRight" value="1"></attribute>
				<attribute name="InstancesProgramAccessRight" value="1"></attribute>
			</variables>
			<variables name="ETH_BKP_ERROR" typeName="BOOL">
				<comment>Ethernet backplane error (0: error, 1: OK)</comment>
				<attribute name="IsVariableHidden" value="-1"></attribute>
				<attribute name="ExtractBit" value="6"></attribute>
				<attribute name="RequestAccessRight" value="1"></attribute>
				<attribute name="InstancesProgramAccessRight" value="1"></attribute>
			</variables>
			<variables name="EIP_SCANNER" typeName="BOOL">
				<comment>0: service not operating normally / 1: service operating normally or disabled</comment>
				<attribute name="ExtractBit" value="7"></attribute>
				<attribute name="RequestAccessRight" value="1"></attribute>
				<attribute name="InstancesProgramAccessRight" value="1"></attribute>
			</variables>
			<variables name="MODBUS_SCANNER" typeName="BOOL">
