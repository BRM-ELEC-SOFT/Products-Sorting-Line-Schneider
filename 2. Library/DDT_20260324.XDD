	<DDTSource DDTName="udtStorage_Conveyors" version="0.10" dateTime="dt#2026-03-17-15:48:04">
		<attribute name="TypeSignatureCheckSumString" value="4B43"></attribute>
		<structure>
			<variables name="State" typeName="INT"></variables>
			<variables name="NextState" typeName="INT"></variables>
			<variables name="RunForward" typeName="BOOL">
				<comment>TRUE = Connected (Line) Object can or should run Forward, this output becomes high when baler is ready for feed (or other recycling/baling machine)</comment>
			</variables>
			<variables name="RunReverse" typeName="BOOL">
				<comment>TRUE = Connected (Line) Object can or should run Reverse, this output becomes high when baler is ready for feed (or other recycling/baling machine)</comment>
			</variables>
			<variables name="ObjectPosition" typeName="INT">
				<comment>Specify object position, in Objects database (LineBase), must be conveyor type</comment>
			</variables>
			<variables name="ForwardName" typeName="string[10]">
				<comment>For reference only</comment>
			</variables>
			<variables name="ReverseName" typeName="string[10]">
				<comment>For reference only</comment>
			</variables>
			<variables name="ConveyorFlowToLocation_Forward" typeName="INT">
				<comment>Specify number of output flow Front to Location. 0 = Default instance (always OK, waiting for mater Conveyor), 1 = Baler 1 (or machine 1), 2 = 2nd location, etc.</comment>
			</variables>
			<variables name="ConveyorFlowToLocation_Reverse" typeName="INT">
				<comment>Specify number of output flow Back to Location. 0 = Default instance (always OK, waiting for mater Conveyor), 1 = Baler 1 (or machine 1), 2 = 2nd location, etc.</comment>
			</variables>
			<variables name="Feedback_FeedFromObject" typeName="BOOL">
				<comment>TRUE = Object that is requested to run is running (ussage is for Storage Conveyor - Run material Forward/Reverse)</comment>
			</variables>
		</structure>
	</DDTSource>
